@* Composant réutilisable de recherche temps réel *@
@* Utilisé par M1 (Clients), M2 (Produits, Factures) *@

<div class="input-group">
    <span class="input-group-text bg-white border-end-0">
        <i class="bi bi-search text-muted"></i>
    </span>
    <input type="text"
           class="form-control border-start-0 ps-0"
           placeholder="@Placeholder"
           value="@_valeur"
           @oninput="OnInput" />
    @if (!string.IsNullOrEmpty(_valeur))
    {
        <button class="btn btn-outline-secondary border-start-0"
                type="button"
                @onclick="Effacer">
            <i class="bi bi-x-lg"></i>
        </button>
    }
</div>

@code {
    // ── Paramètres ────────────────────────────────────────────────────────

    /// <summary>Texte affiché dans le champ vide.</summary>
    [Parameter]
    public string Placeholder { get; set; } = "Rechercher...";

    /// <summary>
    /// Événement déclenché à chaque frappe.
    /// Le parent reçoit la valeur saisie.
    /// </summary>
    [Parameter]
    public EventCallback<string> OnSearchChanged { get; set; }

    // ── État interne ──────────────────────────────────────────────────────

    private string _valeur = string.Empty;

    // ── Méthodes ──────────────────────────────────────────────────────────

    private async Task OnInput(ChangeEventArgs e)
    {
        _valeur = e.Value?.ToString() ?? string.Empty;
        await OnSearchChanged.InvokeAsync(_valeur);
    }

    private async Task Effacer()
    {
        _valeur = string.Empty;
        await OnSearchChanged.InvokeAsync(_valeur);
    }
}