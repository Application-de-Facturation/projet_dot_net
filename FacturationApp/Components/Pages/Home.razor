@* =========================================================
   Fichier : Components/Pages/Home.razor
   Rôle    : Page de connexion — design split-screen attractif
   Layout  : EmptyLayout (pas de sidebar)
   ========================================================= *@

@page "/"
@layout EmptyLayout
@attribute [AllowAnonymous]

@using System.ComponentModel.DataAnnotations

@inject IAuthService AuthService
@inject SessionManager SessionManager
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthState

<PageTitle>Connexion — FacturationApp</PageTitle>

<div class="vh-100 d-flex overflow-hidden">

    @* ── PANNEAU GAUCHE : branding ──────────────────────────────────────── *@
    <div class="d-none d-lg-flex flex-column justify-content-between p-5 text-white"
         style="width:45%; background: linear-gradient(155deg, #0a2342 0%, #1565c0 55%, #1e88e5 100%);">

        @* Logo *@
        <div class="d-flex align-items-center gap-3">
            <div class="rounded-3 p-2 d-flex align-items-center justify-content-center"
                 style="background:rgba(255,255,255,0.15); width:48px; height:48px;">
                <i class="bi bi-receipt-cutoff fs-5"></i>
            </div>
            <span class="fs-4 fw-bold tracking-wide">FacturationApp</span>
        </div>

        @* Titre central *@
        <div>
            <h1 class="display-5 fw-bold lh-sm mb-3">
                Gérez votre<br />facturation<br />en toute simplicité.
            </h1>
            <p class="fs-5 mb-5" style="color:rgba(255,255,255,0.75);">
                Solution complète pour les entreprises tunisiennes — factures, fournisseurs, stock et analytique.
            </p>

            @* Features *@
            @foreach (var (icone, texte) in _features)
            {
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                         style="width:38px; height:38px; background:rgba(255,255,255,0.18);">
                        <i class="bi bi-@icone"></i>
                    </div>
                    <span style="color:rgba(255,255,255,0.85);">@texte</span>
                </div>
            }
        </div>

        @* Pied de page *@
        <p class="small mb-0" style="color:rgba(255,255,255,0.45);">
            © @DateTime.Now.Year FacturationApp · Tous droits réservés
        </p>
    </div>

    @* ── PANNEAU DROIT : formulaire de connexion ─────────────────────────── *@
    <div class="flex-grow-1 d-flex flex-column align-items-center justify-content-center px-3 px-md-4"
         style="background:#f4f6fb; overflow-y:auto;">

        @* Logo mobile (visible uniquement sur petit écran) *@
        <div class="d-lg-none text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center rounded-3 mb-3"
                 style="width:64px; height:64px; background: linear-gradient(135deg, #1565c0, #1e88e5);">
                <i class="bi bi-receipt-cutoff text-white fs-4"></i>
            </div>
            <h4 class="fw-bold text-primary">FacturationApp</h4>
        </div>

        @* Carte de connexion *@
        <div class="card border-0 shadow-lg p-4 p-md-5 w-100" style="max-width: 440px;">

            <h2 class="fw-bold mb-1">Bienvenue</h2>
            <p class="text-muted mb-4">Connectez-vous à votre espace de travail</p>

            @* ── Alerte d'erreur ────────────────────────────────────────── *@
            @if (!string.IsNullOrEmpty(_erreur))
            {
                <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-3" role="alert">
                    <i class="bi bi-exclamation-circle-fill flex-shrink-0"></i>
                    <span>@_erreur</span>
                </div>
            }

            @* ── Formulaire ─────────────────────────────────────────────── *@
            <EditForm Model="_model" OnValidSubmit="Connecter" OnInvalidSubmit="SurSoumissionInvalide"
                      FormName="form-login">
                <DataAnnotationsValidator />

                @* Identifiant *@
                <div class="mb-3">
                    <label class="form-label fw-semibold">Nom d'utilisateur ou Email</label>
                    <div class="input-group">
                        <span class="input-group-text" style="background:#f0f4f8;">
                            <i class="bi bi-person text-secondary"></i>
                        </span>
                        <InputText @bind-Value="_model.Identifiant"
                                   class="form-control"
                                   placeholder="Votre identifiant ou email"
                                   autocomplete="username" />
                    </div>
                    <ValidationMessage For="@(() => _model.Identifiant)" class="text-danger small mt-1" />
                </div>

                @* Mot de passe *@
                <div class="mb-4">
                    <label class="form-label fw-semibold">Mot de passe</label>
                    <div class="input-group">
                        <span class="input-group-text" style="background:#f0f4f8;">
                            <i class="bi bi-lock text-secondary"></i>
                        </span>
                        <input type="@(_showPwd ? "text" : "password")"
                               class="form-control"
                               @bind="_model.MotDePasse"
                               @bind:event="oninput"
                               placeholder="••••••••"
                               autocomplete="current-password" />
                        <button type="button"
                                class="input-group-text"
                                style="background:#f0f4f8; cursor:pointer;"
                                @onclick="() => _showPwd = !_showPwd"
                                title="@(_showPwd ? "Masquer" : "Afficher") le mot de passe">
                            <i class="bi @(_showPwd ? "bi-eye-slash" : "bi-eye") text-secondary"></i>
                        </button>
                    </div>
                    <ValidationMessage For="@(() => _model.MotDePasse)" class="text-danger small mt-1" />
                </div>

                @* Bouton de connexion *@
                <button type="submit"
                        class="btn btn-primary w-100 py-2 fw-semibold"
                        disabled="@_isLoading">
                    @if (_isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        <text>Connexion en cours...</text>
                    }
                    else
                    {
                        <i class="bi bi-box-arrow-in-right me-2"></i>
                        <text>Se connecter</text>
                    }
                </button>
            </EditForm>

            <hr class="my-4" />

            <p class="text-center text-muted mb-0 small">
                Pas encore de compte ?
                <a href="/inscription" class="fw-semibold text-decoration-none">Créer un compte</a>
            </p>
        </div>
    </div>
</div>


@code {
    // ── Modèle du formulaire ───────────────────────────────────────────────

    private class LoginModel
    {
        [Required(ErrorMessage = "L'identifiant est obligatoire.")]
        public string Identifiant { get; set; } = string.Empty;

        [Required(ErrorMessage = "Le mot de passe est obligatoire.")]
        public string MotDePasse { get; set; } = string.Empty;
    }

    // ── État du composant ──────────────────────────────────────────────────

    private readonly LoginModel _model = new();
    private string? _erreur;
    private bool _showPwd;
    private bool _isLoading;

    // ── Features affichées dans le panneau gauche ─────────────────────────
    private static readonly (string Icone, string Texte)[] _features =
    [
        ("receipt",           "Génération de factures avec numérotation automatique"),
        ("truck",             "Gestion des fournisseurs et bons de commande"),
        ("box-seam",          "Suivi du stock en temps réel"),
        ("graph-up-arrow",    "Tableaux de bord analytiques"),
    ];

    // ── Initialisation : si déjà connecté → aller sur /clients ───────────

    protected override async Task OnInitializedAsync()
    {
        // Récupère l'URL pour afficher un message si la session a expiré
        var uri = new Uri(NavigationManager.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        if (query["erreur"] == "1")
            _erreur = "Session expirée. Veuillez vous reconnecter.";

        // Si déjà authentifié, rediriger directement
        var state = await AuthState.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated == true)
            NavigationManager.NavigateTo("/clients", forceLoad: true);
    }

    // ── Soumission valide ──────────────────────────────────────────────────

    private async Task Connecter()
    {
        _erreur = null;
        _isLoading = true;

        try
        {
            var utilisateur = await AuthService.ConnecterAsync(_model.Identifiant, _model.MotDePasse);

            if (utilisateur == null)
            {
                // Message volontairement vague — ne pas indiquer lequel des deux champs est faux
                _erreur = "Identifiant ou mot de passe incorrect.";
                return;
            }

            // Créer un token éphémère → AuthController l'échange contre un cookie HTTP
            var token = SessionManager.CreerToken(utilisateur.Id, utilisateur.NomUtilisateur, utilisateur.Role);
            NavigationManager.NavigateTo($"/auth/signin/{token}", forceLoad: true);
        }
        catch
        {
            _erreur = "Une erreur technique est survenue. Veuillez réessayer.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void SurSoumissionInvalide()
        => _erreur = "Veuillez remplir tous les champs obligatoires.";
}
