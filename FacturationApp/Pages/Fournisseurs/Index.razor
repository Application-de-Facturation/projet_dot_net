@* =========================================================
   Fichier : FacturationApp/Pages/Fournisseurs/Index.razor
   Rôle    : afficher, rechercher et supprimer des fournisseurs
   ========================================================= *@

@page "/fournisseurs"
@using Microsoft.AspNetCore.Components.Web
@using FacturationApp.Data.Entities
@using FacturationApp.Services.Interfaces

@inject IFournisseurService FournisseurService
@inject NavigationManager NavigationManager

<PageTitle>Gestion des Fournisseurs</PageTitle>

@* ── En-tête ────────────────────────────────────────────────────────────── *@
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-truck me-2"></i>Fournisseurs</h2>
    <a href="/fournisseurs/nouveau" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Nouveau fournisseur
    </a>
</div>

@* ── Barre de recherche ────────────────────────────────────────────────── *@
<div class="row mb-3 g-2 align-items-center">
    <div class="col-md-5">
        <input type="text"
               class="form-control"
               placeholder="Rechercher par nom ou matricule fiscal..."
               value="@_termRecherche"
               @oninput="FiltrerFournisseurs" />
    </div>
</div>

@* ── Contenu principal ─────────────────────────────────────────────────── *@
@if (_isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2 text-muted">Chargement des fournisseurs...</p>
    </div>
}
else if (!_fournisseurs.Any())
{
    <div class="alert alert-info d-flex align-items-center">
        <i class="bi bi-info-circle me-2 fs-5"></i>
        <span>Aucun fournisseur trouvé.</span>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Nom</th>
                    <th>Email</th>
                    <th>Téléphone</th>
                    <th>Matricule Fiscal</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in _fournisseurs)
                {
                    <tr>
                        <td class="text-muted small">@f.Id</td>
                        <td class="fw-semibold">@f.Nom</td>
                        <td>@(f.Email ?? "—")</td>
                        <td>@(f.Telephone ?? "—")</td>
                        <td><span class="badge bg-secondary">@(f.MatriculeFiscal ?? "—")</span></td>
                        <td class="text-center">
                            <a href="/fournisseurs/editer/@f.Id"
                               class="btn btn-sm btn-outline-primary me-1" title="Modifier">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <button class="btn btn-sm btn-outline-danger" title="Supprimer"
                                    @onclick="() => ConfirmerSuppression(f.Id)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <p class="text-muted small">
        <i class="bi bi-info-circle me-1"></i>@_fournisseurs.Count fournisseur(s) affiché(s)
    </p>
}

@* ── Modal de confirmation de suppression ─────────────────────────────── *@
@if (_idASupprimer.HasValue)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header border-0">
                    <h5 class="modal-title text-danger">
                        <i class="bi bi-exclamation-triangle me-2"></i>Confirmer la suppression
                    </h5>
                </div>
                <div class="modal-body">
                    Voulez-vous supprimer ce fournisseur ?
                    <br /><small class="text-muted">Cette action est irréversible.</small>
                </div>
                <div class="modal-footer border-0">
                    <button class="btn btn-secondary" @onclick="AnnulerSuppression">Annuler</button>
                    <button class="btn btn-danger" @onclick="ExecuterSuppression">
                        <i class="bi bi-trash me-1"></i>Supprimer
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Fournisseur> _fournisseurs = new();
    private bool _isLoading = true;
    private string _termRecherche = string.Empty;
    private int? _idASupprimer = null;

    protected override async Task OnInitializedAsync()
        => await ChargerFournisseurs();

    private async Task ChargerFournisseurs()
    {
        _isLoading = true;

        if (string.IsNullOrWhiteSpace(_termRecherche))
            _fournisseurs = await FournisseurService.GetAllAsync();
        else
            _fournisseurs = await FournisseurService.SearchAsync(_termRecherche);

        _isLoading = false;
    }

    private async Task FiltrerFournisseurs(ChangeEventArgs e)
    {
        _termRecherche = e.Value?.ToString() ?? string.Empty;
        await ChargerFournisseurs();
    }

    private void ConfirmerSuppression(int id)
        => _idASupprimer = id;

    private void AnnulerSuppression()
        => _idASupprimer = null;

    private async Task ExecuterSuppression()
    {
        if (_idASupprimer.HasValue)
        {
            await FournisseurService.DeleteAsync(_idASupprimer.Value);
            _idASupprimer = null;
            await ChargerFournisseurs();
        }
    }
}
